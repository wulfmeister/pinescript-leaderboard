{
  "name": "pinescript-utils",
  "version": "1.0.0",
  "description": "TypeScript-based testing and development utility suite for PineScript strategies",
  "private": true,
  "packageManager": "npm@11.6.2",
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=!@pinescript-utils/web",
    "build:all": "turbo run build",
    "dev": "npm run build && npm run web",
    "web": "npm run --workspace=web dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "keywords": [
    "pinescript",
    "trading",
    "backtesting",
    "tradingview",
    "technical-analysis"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "turbo": "^2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "workspaces": [
    "packages/*",
    "cli",
    "web"
  ],
  "dependencies": {
    "pinets": "^0.8.12"
  }
}
