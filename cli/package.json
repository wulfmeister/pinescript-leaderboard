    "@pinescript-utils/backtester": "file:../packages/backtester",
    "@pinescript-utils/reporter": "file:../packages/reporter",
    "@pinescript-utils/ranker": "file:../packages/ranker",
    "@pinescript-utils/optimizer": "file:../packages/optimizer",
    "@pinescript-utils/walk-forward": "file:../packages/walk-forward",
    "@pinescript-utils/risk-manager": "file:../packages/risk-manager",
    "@pinescript-utils/monte-carlo": "file:../packages/monte-carlo",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
